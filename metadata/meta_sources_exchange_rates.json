        "datatype": "string",
        "nullable": false
      },

      "exchange_data_rate_groups_currencies_currency_info_target_currency": {
        "datatype": "string",
        "nullable": false
      },

      "exchange_data_rate_groups_currencies_rate_details_exchange_rate": {
        "datatype": "double",
        "nullable": false
      },

      "exchange_data_rate_groups_currencies_rate_details_rate_date": {
        "datatype": "date",
        "nullable": false
      }
    },

    "composite_key": [

      "exchange_data_rate_groups_currencies_currency_info_target_currency",

      "exchange_data_rate_groups_currencies_rate_details_rate_date"

    ],

    "validation_rules": {

      "exchange_data_rate_groups_currencies_rate_details_exchange_rate": {

        "rule_type": "greater_than",

        "value": 0,

        "severity": "ERROR"

      }

    }

  }
}