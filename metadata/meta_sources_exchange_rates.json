{
  "ExchangeRates": {

    "source_name": "ExchangeRates",

    "source_type": "REST",

    "format": "JSON",

    "source_location": "REST_ENDPOINT",

    "ingestion_type": "DailyAPI",

    "bronze_table": "bronze_exchange_rates",

    "silver_table": "silver_exchange_rates",

    "reject_table": "reject_exchange_rates",

    "incremental_config": {

      "load_strategy": "incremental",

      "watermark_column": "exchange_data_rate_groups_currencies_rate_details_rate_date"

    },

    "columns": {

