  "natural_key": "Date",

  "deduplicate": true,

  "derived_attributes": {

    "Year": "year(Date)",

    "Quarter": "quarter(Date)",

    "Month": "month(Date)",

    "MonthName": "date_format(Date,'MMMM')",

    "Day": "dayofmonth(Date)",

    "DayOfWeek": "date_format(Date,'EEEE')"

  },

  "columns": [

    "DateSK",

    "Date",

    "Year",

    "Quarter",

    "Month",

    "MonthName",

    "Day",

    "DayOfWeek"

  ]
}
  },

  "facts": {
    "fact_sales": {
      "source_table": "silver_orders",

      "grain": "One Row Per OrderID",

      "business_keys": [
        "OrderID"
      ],

      "dimension_links": {
        "dim_customer": {
          "fact_key": "CustomerID",
          "dimension_key": "CustomerID",
          "surrogate_key": "CustomerSK"
        },

        "dim_product": {
          "fact_key": "ProductID",
          "dimension_key": "ProductID",
          "surrogate_key": "ProductSK"
        },

        "dim_store": {
          "fact_key": "StoreCode",
          "dimension_key": "StoreCode",
          "surrogate_key": "StoreSK"
        },

        "dim_date": {
          "fact_key": "OrderDate",
          "dimension_key": "Date",
          "surrogate_key": "DateSK"
        }
      },

      "measures": [
        "Quantity",
        "UnitPrice"
      ],

      "derived_measures": {
        "SalesAmount": "Quantity * UnitPrice"
      },

      "final_columns": [
        "OrderID",
        "CustomerSK",
        "ProductSK",
        "StoreSK",
        "DateSK",
        "Quantity",
        "UnitPrice",
        "SalesAmount"
      ]
