{
  "Customers": {

    "source_name": "Customers",

    "source_type": "AzureSQL",

    "format": "Table",

    "source_location": "dbo.Customers",

    "ingestion_type": "WatermarkIncremental",

    "bronze_table": "bronze_customers",

    "silver_table": "silver_customers_scd2",

    "reject_table": "reject_customers",

    "incremental_config": {

      "load_strategy": "incremental",

      "watermark_column": "LastUpdated"
    },

    "scd_config": {
      "scd_type": 2,
      "natural_key": ["CustomerID"],
      "tracked_columns": [
        "City",
        "State"
      ],
      "sequence_column": "LastUpdated",
      "surrogate_key": "CustomerSK"
    },

    "columns": {

      "CustomerID": {
        "datatype": "int",
        "nullable": false,
        "key_type": "NK"
      },

      "FirstName": {
        "datatype": "string",
        "nullable": false
      },

      "LastName": {
        "datatype": "string",
        "nullable": false
      },

      "Email": {
        "datatype": "string",
        "nullable": false
      },

      "Phone": {
        "datatype": "string",
        "nullable": true
      },

      "City": {
        "datatype": "string",
        "nullable": false
      },

      "State": {
        "datatype": "string",
        "nullable": false
      },

      "LastUpdated": {
        "datatype": "timestamp",
        "nullable": false
      }
    },

    "validation_rules": {

      "Email": {
        "rule_type": "regex",
        "pattern": "email",
        "severity": "ERROR"
      }
    }
  }
}